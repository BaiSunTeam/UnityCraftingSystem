root = true

[*.cs]

# Keep braces on same line
csharp_new_line_before_open_brace = none

# Indentation rules
indent_style = space
indent_size = 4
tab_width = 4

# Ensure proper indentation inside blocks
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true

# Formatting behavior when typing
csharp_format_on_return = true
csharp_format_on_close_brace = true